    if mode=="top" then
        nbSz=UDim2.new(1,0,0,NAV_TOP_H); nbPos=UDim2.new(0,0,0,0)
        caSz=UDim2.new(1,0,1,-NAV_TOP_H); caPos=UDim2.new(0,0,0,NAV_TOP_H)
    elseif mode=="bottom" then
        nbSz=UDim2.new(1,0,0,NAV_TOP_H); nbPos=UDim2.new(0,0,1,-NAV_TOP_H)
        caSz=UDim2.new(1,0,1,-NAV_TOP_H); caPos=UDim2.new(0,0,0,0)
    elseif mode=="left" then
        nbSz=UDim2.new(0,NAV_SIDE_W,1,0); nbPos=UDim2.new(0,0,0,0)
        caSz=UDim2.new(1,-NAV_SIDE_W,1,0); caPos=UDim2.new(0,NAV_SIDE_W,0,0)
    else
        nbSz=UDim2.new(0,NAV_SIDE_W,1,0); nbPos=UDim2.new(1,-NAV_SIDE_W,0,0)
        caSz=UDim2.new(1,-NAV_SIDE_W,1,0); caPos=UDim2.new(0,0,0,0)
    end

    NavBar=ni("Frame",{Size=nbSz,Position=nbPos,BackgroundColor3=T.navBg,BorderSizePixel=0,ZIndex=5,ClipsDescendants=isSide},clipInner)
    mkCorner(T.radius,NavBar)
    -- fill the inner flat edge so rounded corners don't bleed into content
    local flatSz,flatPos
    if mode=="top"    then flatSz=UDim2.new(1,0,0.5,0); flatPos=UDim2.new(0,0,0.5,0)
    elseif mode=="bottom" then flatSz=UDim2.new(1,0,0.5,0); flatPos=UDim2.new(0,0,0,0)
    elseif mode=="left"   then flatSz=UDim2.new(0.5,0,1,0); flatPos=UDim2.new(0.5,0,0,0)
    else flatSz=UDim2.new(0.5,0,1,0); flatPos=UDim2.new(0,0,0,0) end
    ni("Frame",{Size=flatSz,Position=flatPos,BackgroundColor3=T.navBg,BorderSizePixel=0,ZIndex=5},NavBar)

    -- separator line between nav and content
    if isHoriz then
        local yp=mode=="top" and UDim2.new(0,0,1,-1) or UDim2.new(0,0,0,0)
        ni("Frame",{Size=UDim2.new(1,0,0,1),Position=yp,BackgroundColor3=T.sep,BorderSizePixel=0,ZIndex=6},NavBar)
    else
        local xp=mode=="left" and UDim2.new(1,-1,0,0) or UDim2.new(0,0,0,0)
        ni("Frame",{Size=UDim2.new(0,1,1,0),Position=xp,BackgroundColor3=T.sep,BorderSizePixel=0,ZIndex=6},NavBar)
    end

    -- traffic-light style window buttons (close/minimize/maximize)
    if mode=="left" or mode=="top" then
        local function macBtn(col,hov,pos_)
            local b=ni("TextButton",{Size=UDim2.new(0,11,0,11),Position=pos_,BackgroundColor3=col,Text="",BorderSizePixel=0,ZIndex=10,AutoButtonColor=false},NavBar)
            mkCorner(6,b)
