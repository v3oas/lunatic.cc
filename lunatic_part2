        end
        local crP,mgP,mxP
        if mode=="top" then
            crP=UDim2.new(1,-43,0.5,-5); mgP=UDim2.new(1,-29,0.5,-5); mxP=UDim2.new(1,-15,0.5,-5)
        else
            crP=UDim2.new(0,8,0,9); mgP=UDim2.new(0,22,0,9); mxP=UDim2.new(0,36,0,9)
        end
        local crBtn=macBtn(Color3.fromRGB(255,88,78),Color3.fromRGB(210,48,38),crP)
        local mgBtn=macBtn(Color3.fromRGB(255,198,38),Color3.fromRGB(210,153,12),mgP)
        local mxBtn=macBtn(Color3.fromRGB(48,208,78),Color3.fromRGB(24,166,48),mxP)
        crBtn.MouseButton1Click:Connect(function()
            tw(MF,{BackgroundTransparency=1},0.2); task.delay(0.22,function() SGui:Destroy() end)
        end)
        local isMin,isMax=false,false; local sSz=MF.Size; local sPs=MF.Position
        mgBtn.MouseButton1Click:Connect(function()
            if isMin then isMin=false; tw(MF,{Size=sSz},0.25,Enum.EasingStyle.Back)
            else isMin=true; sSz=MF.Size; tw(MF,{Size=UDim2.new(0,WIN_W,0,NAV_TOP_H+2)},0.2) end
        end)
        mxBtn.MouseButton1Click:Connect(function()
            if isMax then isMax=false; tw(MF,{Size=sSz,Position=sPs},0.3,Enum.EasingStyle.Back)
            else isMax=true; sSz=MF.Size; sPs=MF.Position
                tw(MF,{Size=UDim2.new(0,980,0,680),Position=UDim2.new(0.5,-490,0.5,-340)},0.3,Enum.EasingStyle.Back)
            end
        end)
    end

    -- brand label
    local brandOff=mode=="left" and 30 or 0
    local brandLbl=ni("TextLabel",{
        Text="lunatic.cc",Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.brand,
        BackgroundTransparency=1,ZIndex=7,TextXAlignment=Enum.TextXAlignment.Left,
    },NavBar)
    table.insert(REG_TEXT,{lbl=brandLbl,role="brand"})
    if isHoriz then
        brandLbl.Size=UDim2.new(0,90,1,0); brandLbl.Position=UDim2.new(0,10,0,0)
    else
        brandLbl.Size=UDim2.new(1,-8,0,18); brandLbl.Position=UDim2.new(0,8,0,brandOff)
    end
    local verLbl=ni("TextLabel",{
        Text="v6",Font=Enum.Font.Gotham,TextSize=8,TextColor3=T.textDim,
        BackgroundTransparency=1,ZIndex=7,TextXAlignment=Enum.TextXAlignment.Left,
    },NavBar)
    table.insert(REG_TEXT,{lbl=verLbl,role="dim"})
    if isHoriz then verLbl.Size=UDim2.new(0,18,0,10); verLbl.Position=UDim2.new(0,10,1,-13)
    else verLbl.Size=UDim2.new(1,-8,0,10); verLbl.Position=UDim2.new(0,8,0,brandOff+20) end

    local topOff=isSide and (mode=="left" and 56 or 20) or 0
    local tabCont=ni("Frame",{BackgroundTransparency=1,ZIndex=6},NavBar)
    local tll=ni("UIListLayout",{Padding=UDim.new(0,2)},tabCont)
    if isHoriz then
        tabCont.Size=UDim2.new(1,-100,1,0); tabCont.Position=UDim2.new(0,100,0,0)
        tll.FillDirection=Enum.FillDirection.Horizontal; tll.VerticalAlignment=Enum.VerticalAlignment.Center
    else
        tabCont.Size=UDim2.new(1,0,1,-topOff); tabCont.Position=UDim2.new(0,0,0,topOff)
        tll.FillDirection=Enum.FillDirection.Vertical; tll.HorizontalAlignment=Enum.HorizontalAlignment.Left
        mkPad(5,5,0,0,tabCont)
    end

    ContentArea=ni("Frame",{Size=caSz,Position=caPos,BackgroundTransparency=1,ClipsDescendants=true,ZIndex=3},clipInner)
    for _,name in ipairs(tabDefs) do if tabPages[name] then tabPages[name].pg.Parent=ContentArea end end

    for _,name in ipairs(tabDefs) do
        local btnSz=isHoriz and UDim2.new(0,76,1,0) or UDim2.new(1,0,0,30)
        local btn=ni("TextButton",{
            Text=name,Font=Enum.Font.GothamBold,TextSize=10,TextColor3=T.tabIdle,
            BackgroundTransparency=1,Size=btnSz,BorderSizePixel=0,ZIndex=7,AutoButtonColor=false,
        },tabCont)
        if isSide then btn.TextXAlignment=Enum.TextXAlignment.Left; mkPad(14,6,0,0,btn) end
        local ind
        if isHoriz then
            ind=ni("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=T.tabInd,BackgroundTransparency=1,BorderSizePixel=0,ZIndex=8},btn)
        else
            local xp=mode=="right" and UDim2.new(0,0,0,0) or UDim2.new(1,-2,0,0)
            ind=ni("Frame",{Size=UDim2.new(0,2,1,0),Position=xp,BackgroundColor3=T.tabInd,BackgroundTransparency=1,BorderSizePixel=0,ZIndex=8},btn)
        end
        navTabBtns[name]=btn; navTabInds[name]=ind
        REG_TABBTNS[name]=btn; REG_TABINDS[name]=ind
        btn.MouseEnter:Connect(function() if _ACTIVE_TAB~=name then tw(btn,{TextColor3=T.tabHover},0.08) end end)
        btn.MouseLeave:Connect(function() if _ACTIVE_TAB~=name then tw(btn,{TextColor3=T.tabIdle},0.08) end end)
        btn.MouseButton1Click:Connect(function() selTab(name) end)
    end

    if _ACTIVE_TAB then local prev=_ACTIVE_TAB; _ACTIVE_TAB=nil; selTab(prev) else selTab("combat") end
end

