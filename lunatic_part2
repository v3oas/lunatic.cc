-- ============================================================
--   live registries — all widgets register here so refreshTheme works
-- ============================================================
local REG_CB={}
local REG_SL={}
local REG_SECHDR={}
local REG_TEXT={}
local REG_TABBTNS={}
local REG_TABINDS={}

-- refreshTheme walks every registered widget and re-colors it
-- called whenever a theme is applied or a color is changed manually
local function refreshTheme()
    for _,cb in ipairs(REG_CB) do
        local on=cb.getState()
        pcall(function()
            cb.box.BackgroundColor3=on and T.cbOn or T.cbOff
            cb.bs.Color=on and T.cbOn or T.cbBorder
            cb.ck.TextColor3=T.cbMark
        end)
    end
    for _,sl in ipairs(REG_SL) do
        pcall(function()
            sl.track.BackgroundColor3=T.slTrack
            sl.fill.BackgroundColor3=T.slFill
            sl.knob.BackgroundColor3=T.slKnob
            sl.ks.Color=T.slFill
            if not sl.ts then
                sl.ts=Instance.new("UIStroke",sl.track); sl.ts.Thickness=1
            end
            sl.ts.Color=T.slFill; sl.ts.Transparency=0.7
        end)
    end
    for _,sh in ipairs(REG_SECHDR) do
        pcall(function() sh.lbl.TextColor3=T.secHdr; sh.line.BackgroundColor3=T.sep end)
    end
    for _,tl in ipairs(REG_TEXT) do
        pcall(function()
            if tl.role=="text"  then tl.lbl.TextColor3=T.text
            elseif tl.role=="dim"   then tl.lbl.TextColor3=T.textDim
            elseif tl.role=="sec"   then tl.lbl.TextColor3=T.secHdr
            elseif tl.role=="brand" then tl.lbl.TextColor3=T.brand end
        end)
    end
    for name,btn in pairs(REG_TABBTNS) do
        pcall(function() btn.TextColor3=(name==_ACTIVE_TAB) and T.tabActive or T.tabIdle end)
    end
    for _,ind in pairs(REG_TABINDS) do
        pcall(function() ind.BackgroundColor3=T.tabInd end)
    end
end

-- ============================================================
--   navbar + tab system
-- ============================================================
local NavBar,ContentArea
local tabDefs={"combat","visuals","mod","players","options","configs"}
local tabPages={}
local navTabBtns={}
local navTabInds={}

if not ContentArea then return end
local function selTab(name)
    if _ACTIVE_TAB==name then return end
    if _ACTIVE_TAB then
        local ob=navTabBtns[_ACTIVE_TAB]; local oi=navTabInds[_ACTIVE_TAB]
        if ob then tw(ob,{TextColor3=T.tabIdle},0.1) end
        if oi then tw(oi,{BackgroundTransparency=1},0.1) end
        if tabPages[_ACTIVE_TAB] then tabPages[_ACTIVE_TAB].pg.Visible=false end
    end
    _ACTIVE_TAB=name
    local nb=navTabBtns[name]; local ni_=navTabInds[name]
    if nb then tw(nb,{TextColor3=T.tabActive},0.1) end
    if ni_ then tw(ni_,{BackgroundTransparency=0},0.1) end
    if tabPages[name] then tabPages[name].pg.Parent=ContentArea; tabPages[name].pg.Visible=true end
end

local function buildNavLayout()
task.wait(0.1)
selTab("Combat")
    if NavBar then NavBar:Destroy() end
    if ContentArea then
        for _,name in ipairs(tabDefs) do
            if tabPages[name] then tabPages[name].pg.Parent=clipInner end
        end
        ContentArea:Destroy()
    end
    for k in pairs(navTabBtns) do navTabBtns[k]=nil end
    for k in pairs(navTabInds) do navTabInds[k]=nil end
    for k in pairs(REG_TABBTNS) do REG_TABBTNS[k]=nil end
    for k in pairs(REG_TABINDS) do REG_TABINDS[k]=nil end

    local mode=T.navMode
    local isHoriz=(mode=="top" or mode=="bottom")
    local isSide=not isHoriz
