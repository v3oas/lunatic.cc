local function selTab(name)
    if _ACTIVE_TAB == name then return end
    if _ACTIVE_TAB then
        local ob=navTabBtns[_ACTIVE_TAB]; local oi=navTabInds[_ACTIVE_TAB]
        if ob then tw(ob,{TextColor3=T.tabIdle},0.1) end
        if oi then tw(oi,{BackgroundTransparency=1},0.1) end
        if tabPages[_ACTIVE_TAB] then tabPages[_ACTIVE_TAB].pg.Visible=false end
    end
    _ACTIVE_TAB = name
    local nb=navTabBtns[name]; local ni_=navTabInds[name]
    if nb then tw(nb,{TextColor3=T.tabActive},0.1) end
    if ni_ then tw(ni_,{BackgroundTransparency=0},0.1) end
    if ContentArea and tabPages[name] then
        tabPages[name].pg.Parent=ContentArea; tabPages[name].pg.Visible=true
    end
end

