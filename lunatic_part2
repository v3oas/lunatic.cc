    local actionRow=ni("Frame",{Size=UDim2.new(1,-12,0,24),Position=UDim2.new(0,6,0,34),BackgroundTransparency=1},infoPanel)
    ni("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,4)},actionRow)
    local specBtn=ni("TextButton",{Text="spectate",Font=Enum.Font.Gotham,TextSize=9,TextColor3=T.text,BackgroundColor3=T.accentDim,BorderSizePixel=0,Size=UDim2.new(0,58,1,0),AutoButtonColor=false},actionRow); mkCorner(4,specBtn)
    local unspecBtn=ni("TextButton",{Text="unspectate",Font=Enum.Font.Gotham,TextSize=9,TextColor3=T.text,BackgroundColor3=Color3.fromRGB(50,35,80),BorderSizePixel=0,Size=UDim2.new(0,74,1,0),AutoButtonColor=false},actionRow); mkCorner(4,unspecBtn)
    local flingBtn=ni("TextButton",{Text="fling",Font=Enum.Font.Gotham,TextSize=9,TextColor3=T.text,BackgroundColor3=Color3.fromRGB(120,30,30),BorderSizePixel=0,Size=UDim2.new(0,40,1,0),AutoButtonColor=false},actionRow); mkCorner(4,flingBtn)
    local _specConn=nil
    specBtn.MouseButton1Click:Connect(function()
        if not selPl or not selPl.Character then return end
        pcall(function()
            if _specConn then _specConn:Disconnect(); _specConn=nil end
            local root=selPl.Character:FindFirstChild("HumanoidRootPart"); if not root then return end
            Cam.CameraType=Enum.CameraType.Scriptable
            _specConn=RunService.RenderStepped:Connect(function()
                if not selPl or not selPl.Character then
                    _specConn:Disconnect(); _specConn=nil; Cam.CameraType=Enum.CameraType.Custom; return
                end
                local r=selPl.Character:FindFirstChild("HumanoidRootPart")
                if r then
                    local offset=r.CFrame*CFrame.new(0,4,-12)
                    Cam.CFrame=CFrame.new(offset.Position,r.Position+Vector3.new(0,1,0))
                end
            end)
        end)
    end)
    unspecBtn.MouseButton1Click:Connect(function()
        pcall(function()
            if _specConn then _specConn:Disconnect(); _specConn=nil end
            local c=LP.Character; local hum=c and c:FindFirstChild("Humanoid")
            Cam.CameraType=Enum.CameraType.Custom; if hum then Cam.CameraSubject=hum end
        end)
    end)
    flingBtn.MouseButton1Click:Connect(function()
        if not selPl or not selPl.Character then return end
        pcall(function()
            local root=selPl.Character:FindFirstChild("HumanoidRootPart")
            if root then root.AssemblyLinearVelocity=Vector3.new(math.random(-1,1)*9999,9999,math.random(-1,1)*9999) end
        end)
    end)
    local plList=ni("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y},L)
    ni("UIListLayout",{Padding=UDim.new(0,3)},plList)
    local function rebuildList()
        for _,ch in ipairs(plList:GetChildren()) do if not ch:IsA("UIListLayout") then ch:Destroy() end end
        for _,pl in ipairs(Players:GetPlayers()) do
            if pl==LP then continue end
            local pb=ni("TextButton",{Text=pl.DisplayName.."  @"..pl.Name,Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.text,BackgroundColor3=T.cbOff,BorderSizePixel=0,Size=UDim2.new(1,0,0,24),TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false},plList)
            mkCorner(5,pb); mkPad(8,0,0,0,pb)
            pb.MouseEnter:Connect(function() tw(pb,{BackgroundColor3=T.accentDim},0.08) end)
            pb.MouseLeave:Connect(function() tw(pb,{BackgroundColor3=selPl==pl and T.accent or T.cbOff},0.08) end)
            pb.MouseButton1Click:Connect(function()
                selPl=pl
                for _,c in ipairs(plList:GetChildren()) do if c:IsA("TextButton") then tw(c,{BackgroundColor3=T.cbOff},0.08) end end
                tw(pb,{BackgroundColor3=T.accentDim},0.08)
                local hum=pl.Character and pl.Character:FindFirstChild("Humanoid")
                local ping="?"; pcall(function() ping=math.floor(pl:GetNetworkPing()*1000) end)
                infoName.Text=pl.DisplayName.." (@"..pl.Name..")"
                infoSub.Text=string.format("hp: %s/%s  •  ping: %sms  •  team: %s",
                    hum and math.floor(hum.Health) or "?",hum and math.floor(hum.MaxHealth) or "?",
                    ping,pl.Team and pl.Team.Name or "none")
                infoPanel.Size=UDim2.new(1,0,0,66); infoPanel.Visible=true
            end)
        end
    end
    rebuildList()
    Players.PlayerAdded:Connect(function() task.delay(0.2,rebuildList) end)
    Players.PlayerRemoving:Connect(function() task.delay(0.2,rebuildList) end)

    -- right col: appearance
    secHdr(R,"appearance")
    cbRow(R,"remove hats",false,function(v)
        if not v then return end
        local c=LP.Character; if not c then return end
        for _,a in ipairs(c:GetChildren()) do if a:IsA("Accessory") then a:Destroy() end end
    end)
    dropRow(R,"body color",{"Default","Black","White","Red","Blue","Purple","Pink","Green"},"Default",function(v)
        local c=LP.Character; if not c then return end
        local cm={Black=BrickColor.new("Really black"),White=BrickColor.new("White"),Red=BrickColor.new("Bright red"),Blue=BrickColor.new("Bright blue"),Purple=BrickColor.new("Bright violet"),Pink=BrickColor.new("Hot pink"),Green=BrickColor.new("Bright green")}
        if not cm[v] then return end
        for _,p in ipairs(c:GetChildren()) do if p:IsA("BasePart") then p.BrickColor=cm[v] end end
    end)
    sldRow(R,"transparency",0,100,0,function(v) return v.."%" end,function(v)
        local c=LP.Character; if not c then return end
        for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.LocalTransparencyModifier=v/100 end end
    end)
end

