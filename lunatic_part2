        local dot=ni("Frame",{Size=UDim2.new(0,10,0,10),Position=UDim2.new(0,6,0.5,-5),BackgroundColor3=isOn_ and T.cbOn or T.cbOff,BorderSizePixel=0,ZIndex=32},row); mkCorner(3,dot)
        ni("TextLabel",{Text=opt,Font=Enum.Font.Gotham,TextSize=9,TextColor3=T.text,BackgroundTransparency=1,Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,20,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=32},row)
