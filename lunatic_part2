local function saveConfig(name)
    pcall(function()
        if not isfolder(CONFIG_PATH) then makefolder(CONFIG_PATH) end
        writefile(CONFIG_PATH..name..".json",HttpService:JSONEncode(getConfigData()))
    end)
end

local function listConfigs()
    local ok,files=pcall(listfiles,CONFIG_PATH)
    if not ok then return {} end
    local configs={}
    for _,f in ipairs(files) do
        if f:sub(-5)==".json" then
            local n=f:match("([^/\\]+)%.json$"); if n then table.insert(configs,n) end
        end
    end
    return configs
end

