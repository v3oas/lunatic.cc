local _colToTKey={}

local function applyTheme(name)
    local th=THEMES[name]; if not th then return end
    for k,v in pairs(th) do T[k]=v end
    if not T.panel then T.panel=T.bg end
    if not T.inputBg then T.inputBg=T.navBg end
    if not T.dropBg then T.dropBg=T.navBg end
    if not T.dropHover then T.dropHover=T.accentDim end
    if not T.scrollbar then T.scrollbar=T.accent end
    if not T.tabHover then T.tabHover=T.accentDim end

    pcall(function()
        MF.BackgroundColor3=T.bg; mfStroke.Color=T.border
        if NavBar then NavBar.BackgroundColor3=T.navBg end
    end)

    -- walk all descendants and apply color by attribute tag
    pcall(function()
        for _,inst in ipairs(MF:GetDescendants()) do
            pcall(function()
                local tag=inst:GetAttribute("ltheme"); if not tag then return end
                if tag=="bg"         then inst.BackgroundColor3=T.bg
                elseif tag=="panel"      then inst.BackgroundColor3=T.panel
                elseif tag=="navBg"      then inst.BackgroundColor3=T.navBg
                elseif tag=="inputBg"    then inst.BackgroundColor3=T.inputBg
                elseif tag=="dropBg"     then inst.BackgroundColor3=T.dropBg
                elseif tag=="border"     then if inst:IsA("UIStroke") then inst.Color=T.border else inst.BackgroundColor3=T.border end
                elseif tag=="sep"        then inst.BackgroundColor3=T.sep
                elseif tag=="accent"     then inst.BackgroundColor3=T.accent
                elseif tag=="accentDim"  then inst.BackgroundColor3=T.accentDim
                elseif tag=="scrollbar"  then pcall(function() inst.ScrollBarImageColor3=T.scrollbar end)
                elseif tag=="slTrack"    then inst.BackgroundColor3=T.slTrack end
            end)
        end
    end)

    for _,entry in ipairs(_colToTKey) do
        local col=T[entry.key]
        if col and entry.ref and entry.ref.cube and entry.ref.cube.Parent then
            entry.ref.cube.BackgroundColor3=col
            entry.ref.setColor(col)
            if entry.ref.onChange then pcall(entry.ref.onChange,col) end
        end
    end
    refreshTheme()
end

