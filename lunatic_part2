local function refreshTheme()
    for _,cb in ipairs(REG_CB) do
        local on=cb.getState()
        pcall(function()
            cb.box.BackgroundColor3=on and T.cbOn or T.cbOff
            cb.bs.Color=on and T.cbOn or T.cbBorder
            cb.ck.TextColor3=T.cbMark
        end)
    end
    for _,sl in ipairs(REG_SL) do
        pcall(function()
            sl.track.BackgroundColor3=T.slTrack; sl.fill.BackgroundColor3=T.slFill
            sl.knob.BackgroundColor3=T.slKnob; sl.ks.Color=T.slFill
            if not sl.ts then sl.ts=Instance.new("UIStroke",sl.track); sl.ts.Thickness=1 end
            sl.ts.Color=T.slFill; sl.ts.Transparency=0.7
        end)
    end
    for _,sh in ipairs(REG_SECHDR) do
        pcall(function() sh.lbl.TextColor3=T.secHdr; sh.line.BackgroundColor3=T.sep end)
    end
    for _,tl in ipairs(REG_TEXT) do
        pcall(function()
            if     tl.role=="text"  then tl.lbl.TextColor3=T.text
            elseif tl.role=="dim"   then tl.lbl.TextColor3=T.textDim
            elseif tl.role=="sec"   then tl.lbl.TextColor3=T.secHdr
            elseif tl.role=="brand" then tl.lbl.TextColor3=T.brand end
        end)
    end
    for name,btn in pairs(REG_TABBTNS) do
        pcall(function() btn.TextColor3=(_ACTIVE_TAB==name) and T.tabActive or T.tabIdle end)
    end
    for _,ind in pairs(REG_TABINDS) do
        pcall(function() ind.BackgroundColor3=T.tabInd end)
    end
    for _,e in ipairs(REG_COL) do
        if e.themeKey and T[e.themeKey] then
            pcall(function() e.setColor(T[e.themeKey]) end)
        end
    end
end

