local function mkPage()
    local pg=ni("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Visible=false},nil)
    local L=ni("ScrollingFrame",{Size=UDim2.new(0.5,-1,1,0),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=T.scrollbar,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y},pg)
    ni("UIListLayout",{Padding=UDim.new(0,0)},L); mkPad(12,10,8,8,L)
    ni("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(0.5,0,0,0),BackgroundColor3=T.sep,BorderSizePixel=0},pg)
    local R=ni("ScrollingFrame",{Size=UDim2.new(0.5,-1,1,0),Position=UDim2.new(0.5,1,0,0),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=T.scrollbar,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y},pg)
    ni("UIListLayout",{Padding=UDim.new(0,0)},R); mkPad(10,12,8,8,R)
    return pg,L,R
end
for _,name in ipairs(tabDefs) do local pg,L,R=mkPage(); tabPages[name]={pg=pg,L=L,R=R} end

