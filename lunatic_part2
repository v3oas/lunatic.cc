local function applyTheme(name)
    local th=THEMES[name]; if not th then return end
    for k,v in pairs(th) do T[k]=v end
    T.inputBg=T.inputBg or T.navBg; T.dropBg=T.dropBg or T.navBg
    T.dropHover=T.dropHover or T.accentDim; T.scrollbar=T.scrollbar or T.accent
    T.tabHover=T.tabHover or T.accentDim; T.accentHover=T.accentHover or T.accent
    T.cbMark=T.cbMark or Color3.new(1,1,1)
    pcall(function()
        tw(MF,{BackgroundColor3=T.bg},0.15)
        mfStroke.Color=T.border
        if NavBar then tw(NavBar,{BackgroundColor3=T.navBg},0.15) end
        if WMFrame then
            for _,l in ipairs(WMFrame:GetDescendants()) do
                if l:IsA("TextLabel") then tw(l,{TextColor3=T.brand},0.15) end
            end
        end
    end)
    refreshTheme()
end

