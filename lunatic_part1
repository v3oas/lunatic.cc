local function revertLocalESP()
    for _,info in ipairs(LocalESP._originals) do
        pcall(function() info.p.Material=info.m; info.p.Color=info.c; info.p.Transparency=info.t end)
    end
    LocalESP._originals={}; LocalESP._applied=false
end
local function applyLocalESP()
    revertLocalESP(); if not LocalESP.Enabled then return end
    local c=LP.Character; if not c then return end
    for _,p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
            table.insert(LocalESP._originals,{p=p,m=p.Material,c=p.Color,t=p.Transparency})
            pcall(function()
                if LocalESP.Material=="Neon" then
                    p.Material=Enum.Material.Neon; p.Color=LocalESP.Color; p.Transparency=0
                elseif LocalESP.Material=="ForceField" then
                    p.Material=Enum.Material.ForceField
                    -- fix: forcefield face texture causes avatar face to show through
                    -- solution: set transparency high enough on face parts
                    if p.Name=="Head" then p.Transparency=1
                    else p.Transparency=math.max(0.05,LocalESP.Transparency) end
                end
            end)
        end
    end
    LocalESP._applied=true
end
