local _notifStack={}  -- active toasts (so they stack upward)
local NOTIF_W,NOTIF_H=220,34
local NOTIF_PAD=6
local NOTIF_X=12  -- from right edge
local NOTIF_Y=12  -- from bottom

local function showNotif(text,color,icon)
    task.spawn(function()
        local vp=Cam.ViewportSize
        local slot=#_notifStack  -- how many are currently visible → stack above them
        local baseY=vp.Y-NOTIF_Y-NOTIF_H
        local startY=baseY-(slot*(NOTIF_H+NOTIF_PAD))

        -- toast frame
        local toast=ni("Frame",{
            Size=UDim2.new(0,NOTIF_W,0,NOTIF_H),
            Position=UDim2.new(0,vp.X-NOTIF_W-NOTIF_X,0,startY+12),  -- slide in from below
            BackgroundColor3=Color3.fromRGB(13,11,20),
            BackgroundTransparency=0.08,
            BorderSizePixel=0,
            ClipsDescendants=false,
        },_notifGui)
        mkCorner(6,toast)

        -- left color accent bar
        local accent_col=color or Color3.fromRGB(120,72,220)
        local bar=ni("Frame",{
            Size=UDim2.new(0,3,1,-8),
            Position=UDim2.new(0,5,0,4),
            BackgroundColor3=accent_col,
            BorderSizePixel=0,
        },toast)
        mkCorner(2,bar)

        -- message text
        ni("TextLabel",{
            Text=text,
            Font=Enum.Font.Gotham,
            TextSize=11,
            TextColor3=Color3.fromRGB(200,185,225),
            BackgroundTransparency=1,
            Size=UDim2.new(1,-18,1,0),
            Position=UDim2.new(0,14,0,0),
            TextXAlignment=Enum.TextXAlignment.Left,
            TextTruncate=Enum.TextTruncate.AtEnd,
        },toast)

        -- subtle border
        mkStroke(Color3.fromRGB(40,25,70),1,toast)

        -- slide-in tween
        tw(toast,{Position=UDim2.new(0,vp.X-NOTIF_W-NOTIF_X,0,startY)},0.18,Enum.EasingStyle.Quint)

        table.insert(_notifStack,toast)

        task.wait(2.6)

        -- fade + slide out
        tw(toast,{Position=UDim2.new(0,vp.X-NOTIF_W-NOTIF_X+8,0,startY)},0.2)
        for alpha=0,1,0.07 do
            pcall(function()
                toast.BackgroundTransparency=0.08+alpha*0.92
                for _,c in ipairs(toast:GetDescendants()) do
                    if c:IsA("TextLabel") then c.TextTransparency=alpha end
                    if c:IsA("Frame") and c~=toast then c.BackgroundTransparency=alpha end
                    if c:IsA("UIStroke") then c.Transparency=alpha end
                end
            end)
            task.wait(0.025)
        end
        pcall(function() toast:Destroy() end)
        for i,t in ipairs(_notifStack) do if t==toast then table.remove(_notifStack,i); break end end
    end)
end

