local function draw3DBox(d,ch,col)
    -- get bounding box corners from character
    local root=ch:FindFirstChild("HumanoidRootPart"); local head=ch:FindFirstChild("Head")
    if not root or not head then
        for i=1,12 do pcall(function() d["E"..i].Visible=false end) end; return
    end
    local sz=Vector3.new(2.5,6,2.5)
    local cf=root.CFrame
    -- 8 world corners
    local c={
        cf*CFrame.new(-sz.X/2, sz.Y/2,-sz.Z/2),cf*CFrame.new(sz.X/2, sz.Y/2,-sz.Z/2),
        cf*CFrame.new(sz.X/2, sz.Y/2, sz.Z/2),cf*CFrame.new(-sz.X/2, sz.Y/2, sz.Z/2),
        cf*CFrame.new(-sz.X/2,-sz.Y/2,-sz.Z/2),cf*CFrame.new(sz.X/2,-sz.Y/2,-sz.Z/2),
        cf*CFrame.new(sz.X/2,-sz.Y/2, sz.Z/2),cf*CFrame.new(-sz.X/2,-sz.Y/2, sz.Z/2),
    }
    local pts={}; local allOn=true
    for i,cc in ipairs(c) do
        local sp,on=w2s(cc.Position); pts[i]=sp; if not on then allOn=false end
    end
    if not allOn then for i=1,12 do pcall(function() d["E"..i].Visible=false end) end; return end
    -- 12 edges: top 4, bottom 4, vertical 4
    local edges={{1,2},{2,3},{3,4},{4,1},{5,6},{6,7},{7,8},{8,5},{1,5},{2,6},{3,7},{4,8}}
    for i,e in ipairs(edges) do
        pcall(function()
            d["E"..i].From=pts[e[1]]; d["E"..i].To=pts[e[2]]
            d["E"..i].Color=col; d["E"..i].Visible=true
        end)
    end
end

local function updateESP(pl)
    if pl==LP then return end
    makeESP(pl)
    local d=espData[pl]
    local ch=pl.Character; if not ch then hideESP(pl); return end
    local hum=ch:FindFirstChild("Humanoid"); if not hum then hideESP(pl); return end
    if hum.Health<=0 then hideESP(pl); return end
    -- dist limit
    local myR=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local root=ch:FindFirstChild("HumanoidRootPart"); local head=ch:FindFirstChild("Head")
    if not root or not head then hideESP(pl); return end
    if myR and ESP.DistLimit<math.huge and (myR.Position-root.Position).Magnitude>ESP.DistLimit then hideESP(pl); return end
    -- vis only (allow rendering even if player is off screen, hide only when truly invisible)
    if ESP.VisOnly and not canSee(ch) then hideESP(pl); return end
    local tV=w2s(head.Position+Vector3.new(0,head.Size.Y/2+0.3,0))
    local bV=w2s(root.Position-Vector3.new(0,3.1,0))
    local cV,on=w2s(root.Position)
    -- allow if any part is on screen; only fully hide when character cant be projected at all
    if not on and not (w2s(head.Position)) then hideESP(pl); return end
    local ht=math.abs(tV.Y-bV.Y); local wd=ht*0.55
    local Lx,Rx,Ty,By=cV.X-wd/2,cV.X+wd/2,tV.Y,bV.Y
    local cl=ht*0.22
    -- 2d box
    local sb=ESP.Enabled and ESP.BoxEnabled and ESP.BoxMode=="2D"
    pcall(function()
        d.BT.From=Vector2.new(Lx,Ty);d.BT.To=Vector2.new(Rx,Ty);d.BT.Color=ESP.BoxColor;d.BT.Visible=sb
        d.BB.From=Vector2.new(Lx,By);d.BB.To=Vector2.new(Rx,By);d.BB.Color=ESP.BoxColor;d.BB.Visible=sb
        d.BL.From=Vector2.new(Lx,Ty);d.BL.To=Vector2.new(Lx,By);d.BL.Color=ESP.BoxColor;d.BL.Visible=sb
        d.BR.From=Vector2.new(Rx,Ty);d.BR.To=Vector2.new(Rx,By);d.BR.Color=ESP.BoxColor;d.BR.Visible=sb
    end)
    -- corner box
    local cb=ESP.Enabled and ESP.BoxEnabled and ESP.BoxMode=="Corner"
    pcall(function()
        d.C1.From=Vector2.new(Lx,Ty);d.C1.To=Vector2.new(Lx+cl,Ty);d.C1.Color=ESP.BoxColor;d.C1.Visible=cb
        d.C2.From=Vector2.new(Lx,Ty);d.C2.To=Vector2.new(Lx,Ty+cl);d.C2.Color=ESP.BoxColor;d.C2.Visible=cb
        d.C3.From=Vector2.new(Rx,Ty);d.C3.To=Vector2.new(Rx-cl,Ty);d.C3.Color=ESP.BoxColor;d.C3.Visible=cb
        d.C4.From=Vector2.new(Rx,Ty);d.C4.To=Vector2.new(Rx,Ty+cl);d.C4.Color=ESP.BoxColor;d.C4.Visible=cb
        d.C5.From=Vector2.new(Lx,By);d.C5.To=Vector2.new(Lx+cl,By);d.C5.Color=ESP.BoxColor;d.C5.Visible=cb
        d.C6.From=Vector2.new(Lx,By);d.C6.To=Vector2.new(Lx,By-cl);d.C6.Color=ESP.BoxColor;d.C6.Visible=cb
        d.C7.From=Vector2.new(Rx,By);d.C7.To=Vector2.new(Rx-cl,By);d.C7.Color=ESP.BoxColor;d.C7.Visible=cb
        d.C8.From=Vector2.new(Rx,By);d.C8.To=Vector2.new(Rx,By-cl);d.C8.Color=ESP.BoxColor;d.C8.Visible=cb
    end)
    -- hide all edge lines before 3d logic
    for i=1,12 do pcall(function() d["E"..i].Visible=false end) end
    if ESP.Enabled and ESP.BoxEnabled and ESP.BoxMode=="3D" then draw3DBox(d,ch,ESP.BoxColor) end
    -- name
    pcall(function()
        local nameText=""
        if ESP.NameMode=="Display" then nameText=pl.DisplayName
        elseif ESP.NameMode=="Username" then nameText=pl.Name
        elseif ESP.NameMode=="Both" then nameText=pl.DisplayName.." @"..pl.Name end
        d.N.Position=Vector2.new(cV.X,Ty-17); d.N.Text=nameText; d.N.Color=ESP.NameColor; d.N.Visible=ESP.Enabled and ESP.Names
    end)
    -- health bar
    pcall(function()
        local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
        d.HBG.From=Vector2.new(Lx-6,Ty);d.HBG.To=Vector2.new(Lx-6,By)
        d.HFG.From=Vector2.new(Lx-6,By);d.HFG.To=Vector2.new(Lx-6,By-ht*pct)
        d.HFG.Color=ESP.HealthColor; d.HBG.Visible=ESP.Enabled and ESP.Health; d.HFG.Visible=ESP.Enabled and ESP.Health
    end)
    -- distance
    pcall(function()
        if myR then d.DT.Text=math.floor((root.Position-myR.Position).Magnitude).."m" end
        d.DT.Position=Vector2.new(cV.X,By+5); d.DT.Color=ESP.DistColor; d.DT.Visible=ESP.Enabled and ESP.Distance
    end)
    -- tracer
    pcall(function()
        local vp=Cam.ViewportSize; local orig
        if ESP.TracerOrigin=="Mouse" then orig=UserInputService:GetMouseLocation()
        elseif ESP.TracerOrigin=="Top" then orig=Vector2.new(vp.X/2,0)
        elseif ESP.TracerOrigin=="Middle" then local mh=LP.Character and LP.Character:FindFirstChild("Head"); orig=mh and w2s(mh.Position) or Vector2.new(vp.X/2,vp.Y/2)
        else orig=Vector2.new(vp.X/2,vp.Y) end
        d.TR.From=orig; d.TR.To=cV; d.TR.Color=ESP.TracerColor; d.TR.Visible=ESP.Enabled and ESP.Tracer
    end)
    -- skeleton
    pcall(function()
        local skVis=ESP.Enabled and ESP.Skeleton
        -- hide all first
        for i=1,12 do local sk=d["SK"..i]; if sk then sk.Visible=false end end
        if not skVis then return end
        -- resolve parts: try R6 names then R15 names
        local function bp(...) for _,n in ipairs({...}) do local p=ch:FindFirstChild(n); if p then return p end end end
        local hd    = bp("Head")
        local neck  = bp("Torso","UpperTorso")               -- neck/shoulder origin
        local lower = bp("HumanoidRootPart","LowerTorso")    -- hip origin
        local lsho  = bp("Left Arm","LeftUpperArm")
        local rsho  = bp("Right Arm","RightUpperArm")
        local lelb  = bp("Left Arm","LeftLowerArm")          -- R6: same as upper; R15: separate
        local relb  = bp("Right Arm","RightLowerArm")
        local lhan  = bp("Left Arm","LeftHand")
        local rhan  = bp("Right Arm","RightHand")
        local lhip  = bp("Left Leg","LeftUpperLeg")
        local rhip  = bp("Right Leg","RightUpperLeg")
        local lkne  = bp("Left Leg","LeftLowerLeg")
        local rkne  = bp("Right Leg","RightLowerLeg")
        local lfoo  = bp("Left Leg","LeftFoot")
        local rfoo  = bp("Right Leg","RightFoot")
        local root  = bp("HumanoidRootPart")
        -- bone connections
        local bones={
            {hd,neck},      -- head → torso
            {neck,lsho},    -- torso → left shoulder
            {neck,rsho},    -- torso → right shoulder
            {lsho,lelb},    -- left upper → lower arm
            {rsho,relb},    -- right upper → lower arm
            {lelb,lhan},    -- left elbow → hand
            {relb,rhan},    -- right elbow → hand
            {neck,lower},   -- upper torso → lower torso / root
            {lower,lhip},   -- hip → left upper leg
            {lower,rhip},   -- hip → right upper leg
            {lhip,lkne},    -- left knee
            {rhip,rkne},    -- right knee
        }
        for i,b in ipairs(bones) do
            local sk=d["SK"..i]; if not sk then continue end
            if b[1] and b[2] then
                local pa,aOn=w2s(b[1].Position); local pb,bOn=w2s(b[2].Position)
                sk.From=pa; sk.To=pb; sk.Color=ESP.SkeletonColor
                sk.Thickness=1.2; sk.Visible=aOn and bOn
            end
        end
    end)
    -- head dot
