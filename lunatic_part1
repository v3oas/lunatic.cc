-- ─── no fall damage ──────────────────
RunService.Heartbeat:Connect(function()
    if not MiscMov.NoFallDmg then return end
    local c=LP.Character; local hum=c and c:FindFirstChild("Humanoid"); if not hum then return end
    local st=hum:GetState()
    -- prevent float: only cancel fall state, do not override landing
    if st==Enum.HumanoidStateType.Freefall then
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
