-- ─── silent aim hook ─────────────────
pcall(function()
    local hooked={}
    local function getSAPos()
        if not _saTarget then return nil,nil end
        local root=_saTarget.Parent and _saTarget.Parent:FindFirstChild("HumanoidRootPart")
        local pos=_saTarget.Position
        if SA.Prediction and root then pos=predPos(root,SA.PredX,SA.PredY) end
        return pos, _saTarget
    end
    local function hookRem(rem)
        if hooked[rem] then return end; hooked[rem]=true
        local origFire=rem.FireServer
        rem.FireServer=function(self,...)
            if SA.Enabled and _saTarget then
                local pos,part=getSAPos()
                local args={...}; local done=false
                for i,v in ipairs(args) do
                    if typeof(v)=="Vector3" and not done then
                        args[i]=pos or v; done=true
                    elseif typeof(v)=="Instance" and v:IsA("BasePart") and not done then
                        args[i]=part or v; done=true
                    elseif typeof(v)=="CFrame" and not done then
                        -- Arsenal uses CFrame for aim direction
                        if pos then args[i]=CFrame.new(v.Position,pos) end; done=true
                    end
                end
                return origFire(self,table.unpack(args))
            end
            return origFire(self,...)
        end
    end
    local function scanRems(inst)
        for _,v in ipairs(inst:GetDescendants()) do if v:IsA("RemoteEvent") then hookRem(v) end end
        inst.DescendantAdded:Connect(function(v) if v:IsA("RemoteEvent") then hookRem(v) end end)
    end
    scanRems(workspace); scanRems(game:GetService("ReplicatedStorage"))
    -- also hook tool remotes when equipped
    LP.CharacterAdded:Connect(function(c)
        c.ChildAdded:Connect(function(t)
            if t:IsA("Tool") then task.delay(0.1,function() scanRems(t) end) end
        end)
    end)
    if LP.Character then
        LP.Character.ChildAdded:Connect(function(t)
            if t:IsA("Tool") then task.delay(0.1,function() scanRems(t) end) end
        end)
    end
end)

