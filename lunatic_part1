local _snowEnabled=false
local _snowRate=35
local _snowFlakes={}
local _snowDir=Vector2.new(0.3,1)

local function spawnSnowflake(vp)
    local ok,f=pcall(Drawing.new,"Square")
    if not ok then return end
    local sz=math.random(6,14) -- chunky
    f.Filled=true
    f.Color=Color3.new(1,1,1)
    f.Transparency=math.random(20,55)/100
    f.Size=Vector2.new(sz,sz)
    f.Rotation=math.random(0,45)
    f.Position=Vector2.new(math.random(-20,vp.X+20), -sz-10) -- spawn above screen
    f.ZIndex=2
    f.Visible=true
    table.insert(_snowFlakes,{d=f,sz=sz,spd=math.random(60,130),rot=math.random(-30,30),wobble=math.random()*math.pi*2})
end

local _snowTime=0
RunService.RenderStepped:Connect(function(dt)
    local vp=Cam.ViewportSize
    local on=_snowEnabled and WorldFX.WeatherMode=="Snow" and uiVisible
    -- clean up when disabled
    if not on then
        for _,sf in ipairs(_snowFlakes) do pcall(function() sf.d:Remove() end) end
        _snowFlakes={}; _snowTime=0; return
    end
    _snowTime=_snowTime+dt
    -- spawn new flakes
    if math.random() < dt*_snowRate then spawnSnowflake(vp) end
    -- update existing
    for i=#_snowFlakes,1,-1 do
        local sf=_snowFlakes[i]
        local wobbleX=math.sin(_snowTime*1.2+sf.wobble)*18
        sf.d.Position=sf.d.Position+Vector2.new((_snowDir.X*sf.spd+wobbleX)*dt,_snowDir.Y*sf.spd*dt)
        sf.d.Rotation=sf.d.Rotation+sf.rot*dt
        -- remove if below screen (let them fully exit)
        if sf.d.Position.Y>vp.Y+sf.sz+10 then
            pcall(function() sf.d:Remove() end)
            table.remove(_snowFlakes,i)
        end
    end
end)

