        d.C2.From=Vector2.new(Lx,Ty);d.C2.To=Vector2.new(Lx,Ty+cl);d.C2.Color=ESP.BoxColor;d.C2.Thickness=ESP.BoxThick;d.C2.Visible=cb
        d.C3.From=Vector2.new(Rx,Ty);d.C3.To=Vector2.new(Rx-cl,Ty);d.C3.Color=ESP.BoxColor;d.C3.Thickness=ESP.BoxThick;d.C3.Visible=cb
        d.C4.From=Vector2.new(Rx,Ty);d.C4.To=Vector2.new(Rx,Ty+cl);d.C4.Color=ESP.BoxColor;d.C4.Thickness=ESP.BoxThick;d.C4.Visible=cb
        d.C5.From=Vector2.new(Lx,By);d.C5.To=Vector2.new(Lx+cl,By);d.C5.Color=ESP.BoxColor;d.C5.Thickness=ESP.BoxThick;d.C5.Visible=cb
        d.C6.From=Vector2.new(Lx,By);d.C6.To=Vector2.new(Lx,By-cl);d.C6.Color=ESP.BoxColor;d.C6.Thickness=ESP.BoxThick;d.C6.Visible=cb
        d.C7.From=Vector2.new(Rx,By);d.C7.To=Vector2.new(Rx-cl,By);d.C7.Color=ESP.BoxColor;d.C7.Thickness=ESP.BoxThick;d.C7.Visible=cb
        d.C8.From=Vector2.new(Rx,By);d.C8.To=Vector2.new(Rx,By-cl);d.C8.Color=ESP.BoxColor;d.C8.Thickness=ESP.BoxThick;d.C8.Visible=cb
    end)
