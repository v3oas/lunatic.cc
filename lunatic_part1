local function tw(obj,props,dur,style,dir)
    TweenService:Create(obj,TweenInfo.new(dur or 0.18,style or Enum.EasingStyle.Quint,dir or Enum.EasingDirection.Out),props):Play()
end
local function ni(class,props,parent)
    local o=Instance.new(class)
    for k,v in pairs(props or {}) do pcall(function() o[k]=v end) end
    if parent then o.Parent=parent end; return o
end
local function mkCorner(r,p) return ni("UICorner",{CornerRadius=UDim.new(0,r or 6)},p) end
local function mkStroke(col,thick,p) return ni("UIStroke",{Color=col,Thickness=thick or 1},p) end
local function mkPad(l,r,t,b,p) return ni("UIPadding",{PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0)},p) end
local function spacer(p,h) ni("Frame",{Size=UDim2.new(1,0,0,h or 4),BackgroundTransparency=1},p) end

local function colorToHex(c) return string.format("%02X%02X%02X",math.clamp(math.floor(c.R*255+.5),0,255),math.clamp(math.floor(c.G*255+.5),0,255),math.clamp(math.floor(c.B*255+.5),0,255)) end
local function hexToColor(h)
    h=(h or ""):gsub("#",""); if #h~=6 then return nil end
    local r=tonumber(h:sub(1,2),16); local g=tonumber(h:sub(3,4),16); local b=tonumber(h:sub(5,6),16)
    if r and g and b then return Color3.fromRGB(r,g,b) end
end

