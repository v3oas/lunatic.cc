local KBRegistry={}
local function regKB(name,defKey,defMode)
    local e={name=name,key=defKey or Enum.KeyCode.Unknown,mode=defMode or "Toggle",state=false,callbacks={}}
    table.insert(KBRegistry,e); return e
end
local function kbFire(e,val) e.state=val; for _,cb in ipairs(e.callbacks) do pcall(cb,val) end end
local function addKBCb(e,fn) table.insert(e.callbacks,fn) end
local function getKeyName(k) return (not k or k==Enum.KeyCode.Unknown) and "—" or k.Name end

UserInputService.InputBegan:Connect(function(inp,gpe)
    if gpe then return end
    for _,e in ipairs(KBRegistry) do
        if e.mode~="Always" and e.mode~="Off" and inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==e.key then
            if e.mode=="Toggle" then kbFire(e,not e.state)
            elseif e.mode=="Hold" or e.mode=="NoHeld" then kbFire(e,true) end
        end
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    for _,e in ipairs(KBRegistry) do
        if e.mode=="Hold" and inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==e.key then kbFire(e,false) end
    end
end)

