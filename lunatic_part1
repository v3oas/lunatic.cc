-- packets are delayed by yielding the replication thread via task.defer batching
local _fakeLagConn
local function setFakeLag(enabled,frames)
    if _fakeLagConn then _fakeLagConn:Disconnect(); _fakeLagConn=nil end
    if not enabled then return end
    _fakeLagConn=RunService.Heartbeat:Connect(function()
        if not FakeLag.Enabled then _fakeLagConn:Disconnect(); return end
        local c=LP.Character; local root=c and c:FindFirstChild("HumanoidRootPart"); if not root then return end
        -- hold replicated cframe for N frames by constantly reassigning
        local saved=root.CFrame
        for i=1,math.clamp(FakeLag.Frames,0,30) do
            task.defer(function() pcall(function() root.CFrame=saved end) end)
        end
    end)
end

