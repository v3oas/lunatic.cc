local function canSee(char)
    local root=char:FindFirstChild("HumanoidRootPart"); if not root then return false end
    local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude
    local ign={workspace.Terrain}; if LP.Character then table.insert(ign,LP.Character) end
    rp.FilterDescendantsInstances=ign
    local o=Cam.CFrame.Position
    local res=workspace:Raycast(o,(root.Position-o)*0.999,rp)
    return res~=nil and res.Instance~=nil and res.Instance:IsDescendantOf(char)
end

local function aimCenter(useMouse)
    if useMouse then return UserInputService:GetMouseLocation() end
    local vp=Cam.ViewportSize; return Vector2.new(vp.X/2,vp.Y/2)
end

local function predPos(root,predX,predY)
    if not root then return root.Position end
    local vel=root.AssemblyLinearVelocity
    return root.Position+Vector3.new(vel.X*predX*0.05,vel.Y*predY*0.05,vel.Z*predX*0.05)
end

local function isKnocked(pl)
    local ch=pl.Character; if not ch then return false end
    local hum=ch:FindFirstChild("Humanoid"); if not hum then return false end
    return hum.Health<=0
end

local function getBestTarget(fovR,useMouse,parts,vis,team,distLim,healthMin,knockCheck)
    local ctr=aimCenter(useMouse)
    local bPl,bPart,bDist=nil,nil,math.huge
    local myR=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        if team and LP.Team and pl.Team==LP.Team then continue end
        local ch=pl.Character; if not ch then continue end
        local hum=ch:FindFirstChild("Humanoid"); if not hum then continue end
        if hum.Health<=0 then continue end
        if healthMin and healthMin>0 and hum.Health<healthMin then continue end
        if knockCheck and isKnocked(pl) then continue end
        if myR and distLim and distLim<math.huge then
            local er=ch:FindFirstChild("HumanoidRootPart")
            if er and (myR.Position-er.Position).Magnitude>distLim then continue end
        end
        if vis and not canSee(ch) then continue end
        local bestLP,bestLD=nil,math.huge
        for _,pname in ipairs(parts) do
            local pp=ch:FindFirstChild(pname)
            if pp then
                local sp,on=Cam:WorldToViewportPoint(pp.Position)
                if on then
                    local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
                    if d<bestLD then bestLD=d; bestLP=pp end
                end
            end
        end
        if not bestLP then continue end
        local sp,on=Cam:WorldToViewportPoint(bestLP.Position); if not on then continue end
        local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
        if d<=fovR and d<bDist then bDist=d; bPl=pl; bPart=bestLP end
    end
    return bPl,bPart
end

local function w2s(pos)
    local sp,on=Cam:WorldToViewportPoint(pos)
    local vp=Cam.ViewportSize
    local visible=on and sp.Z>0 and sp.X>-300 and sp.X<vp.X+300 and sp.Y>-300 and sp.Y<vp.Y+300
    return Vector2.new(sp.X,sp.Y),visible
end

