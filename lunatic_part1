-- triggerbot
RunService.Heartbeat:Connect(function()
    if not TB.Enabled then return end
    local ctr=aimCenter(false)
    local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude
    local ign={workspace.Terrain}; if LP.Character then table.insert(ign,LP.Character) end
    rp.FilterDescendantsInstances=ign
    local mult=TB.HitboxMult or 1; local r=(mult-1)*22
    local offsets={Vector2.new(0,0)}
    if mult>1 then for _,o in ipairs({Vector2.new(r,0),Vector2.new(-r,0),Vector2.new(0,r),Vector2.new(0,-r)}) do table.insert(offsets,o) end end
    local hitPl,hitPart=nil,nil
    for _,off in ipairs(offsets) do
        local ray=Cam:ScreenPointToRay(ctr.X+off.X,ctr.Y+off.Y)
        local res=workspace:Raycast(ray.Origin,ray.Direction*1500,rp)
        if res and res.Instance then
            local par=res.Instance.Parent
            local pl=Players:GetPlayerFromCharacter(par) or Players:GetPlayerFromCharacter(par and par.Parent)
            if pl and pl~=LP then
                if TB.TeamCheck and LP.Team and pl.Team==LP.Team then continue end
                if TB.VisCheck and not canSee(pl.Character) then continue end
                local ok=false
                for _,pn in ipairs(TB.HitParts) do if pn=="All" or res.Instance.Name==pn then ok=true; break end end
                if ok and not TB._firing then hitPl=pl; hitPart=res.Instance; break end
            end
        end
    end
    if not hitPl or TB._firing then return end
    TB._firing=true
    task.spawn(function()
        task.wait(TB.Delay)
        pcall(function()
            local vim=game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(0,0,0,true,game,1); task.wait(0.055)
            vim:SendMouseButtonEvent(0,0,0,false,game,1)
        end)
        TB._firing=false
    end)
end)

-- ═══════════════════════════════════════
--   SILENT AIM — __namecall dual hook
--
--   Arsenal/Rivals use workspace:Raycast() (new API) for hit detection.
--   We intercept __namecall and handle two cases:
--
--   1. workspace:Raycast(origin, direction, params)
--      → redirect direction toward target for rays longer than 50 studs
--        (short rays = camera collision, skip those)
--
--   2. RemoteEvent:FireServer(...) / InvokeServer(...)
--      → replace unit-vector direction arguments (magnitude ≈ 1)
--        so the server registers a hit on the target
--
--   Also keep FindPartOnRayWithIgnoreList as a third fallback
--   for older games that still use the legacy API.
-- ═══════════════════════════════════════
local _saTarget=nil

local function _saGetPos()
    if not (_saTarget and _saTarget.Parent) then return nil end
    local pos=_saTarget.Position
    if SA.Prediction then
        local root=_saTarget.Parent:FindFirstChild("HumanoidRootPart")
        if root then
            local v=root.AssemblyLinearVelocity
            pos=pos+Vector3.new(v.X*SA.PredX*0.05,v.Y*SA.PredY*0.05,v.Z*SA.PredX*0.05)
        end
    end
    return pos
end

-- PRIMARY: __namecall hook — workspace:Raycast + RemoteEvent:FireServer
pcall(function()
    if not hookmetamethod then return end
    local oldNC
    oldNC=hookmetamethod(game,"__namecall",newcclosure(function(self,...)
        local method=getnamecallmethod()

        if SA.Enabled then
            -- ── workspace:Raycast ──────────────────────────────────────────
            if method=="Raycast" and (self==workspace or pcall(function() return self:IsA("WorldRoot") end) and self:IsA("WorldRoot")) then
                local args={...}
                local origin=args[1]; local dir=args[2]; local params=args[3]
                if typeof(origin)=="Vector3" and typeof(dir)=="Vector3" then
                    local rayLen=dir.Magnitude
                    if rayLen>50 then  -- skip short camera-collision rays
                        local tPos=_saGetPos()
                        if tPos then
                            local newDir=(tPos-origin).Unit*rayLen
                            if params then return oldNC(self,origin,newDir,params)
                            else return oldNC(self,origin,newDir) end
                        end
                    end
                end

            -- ── RemoteEvent:FireServer / InvokeServer ──────────────────────
            elseif (method=="FireServer" or method=="InvokeServer") and typeof(self)=="Instance" and self:IsA("RemoteEvent") or (typeof(self)=="Instance" and self:IsA("RemoteFunction") and method=="InvokeServer") then
                local tPos=_saGetPos()
                if tPos then
                    local args={...}; local camPos=Cam.CFrame.Position; local replaced=false
                    for i,v in ipairs(args) do
                        if not replaced then
                            if typeof(v)=="Vector3" then
                                local mag=v.Magnitude
                                -- unit vectors (direction) have magnitude ≈ 1
                                -- world positions have magnitude >> 1 (usually 100+ from origin)
                                if mag>0.5 and mag<2 then
                                    args[i]=(tPos-camPos).Unit; replaced=true
                                end
                            elseif typeof(v)=="CFrame" then
                                args[i]=CFrame.new(v.Position,tPos); replaced=true
                            end
                        end
                    end
                    if replaced then return oldNC(self,table.unpack(args)) end
                end
            end
        end

        return oldNC(self,...)
    end))
end)

-- SECONDARY: hookfunction workspace.Raycast (some executors expose this directly)
pcall(function()
    if not hookfunction or not workspace.Raycast then return end
    local origR=hookfunction(workspace.Raycast,newcclosure(function(ws,origin,dir,params,...)
        if SA.Enabled and typeof(dir)=="Vector3" and dir.Magnitude>50 then
            local tPos=_saGetPos()
            if tPos then
                local newDir=(tPos-origin).Unit*dir.Magnitude
                if params then return origR(ws,origin,newDir,params,...)
                else return origR(ws,origin,newDir,...) end
            end
        end
        return origR(ws,origin,dir,params,...)
    end))
end)

-- TERTIARY: legacy FindPartOnRayWithIgnoreList (older game codebases)
pcall(function()
