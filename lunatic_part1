-- ─── CFRAME MOVEMENT (replaces vsync) ──────────
-- moves character by directly setting HumanoidRootPart.CFrame each frame
-- smooth, server-safe movement without velocity artifacts
RunService.RenderStepped:Connect(function(dt)
    if not CFrameMove.Enabled then return end
    local c=LP.Character; if not c then return end
    local root=c:FindFirstChild("HumanoidRootPart"); if not root then return end
    local hum=c:FindFirstChild("Humanoid"); if not hum then return end
    local dir=hum.MoveDirection
    if dir.Magnitude>0.01 then
        -- Move using CFrame translation — bypasses physics engine smoothly
        local move=dir.Unit*CFrameMove.Speed*dt
        root.CFrame=root.CFrame+move
    end
end)

-- ─── CFRAME FLY ──────────────────────
-- Uses CFrame to move the character through the air directly
-- More reliable than velocity-based fly; camera-relative WASD controls
local _cffWasOn=false
RunService.RenderStepped:Connect(function(dt)
    local c=LP.Character; if not c then return end
    local root=c:FindFirstChild("HumanoidRootPart"); if not root then return end
    local hum=c:FindFirstChild("Humanoid"); if not hum then return end

    if _cffWasOn and not CFrameFly.Enabled then
        _cffWasOn=false
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Physics,false) end)
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        return
    end
    if not CFrameFly.Enabled then return end
    _cffWasOn=true

    -- Freeze physics so gravity doesn't pull character down
    pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Physics,true) end)
    hum:ChangeState(Enum.HumanoidStateType.Physics)

    local cf=Cam.CFrame
    local mv=Vector3.zero
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv=mv+cf.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv=mv-cf.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv=mv-cf.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv=mv+cf.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv=mv+Vector3.new(0,1,0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then mv=mv-Vector3.new(0,1,0) end

    if mv.Magnitude>0.001 then
        -- Directly set CFrame position (no velocity, no physics drift)
        local newPos=root.Position+mv.Unit*CFrameFly.Speed*dt
        root.CFrame=CFrame.new(newPos)*CFrame.Angles(0,math.atan2(-cf.LookVector.X,-cf.LookVector.Z),0)
    end
end)

