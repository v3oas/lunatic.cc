local function updateESP(pl)
    if pl==LP then return end
    makeESP(pl)
    local d=espData[pl]
    local ch=pl.Character; if not ch then hideESP(pl); return end
    local hum=ch:FindFirstChild("Humanoid"); if not hum then hideESP(pl); return end
    if hum.Health<=0 then hideESP(pl); return end
    -- team check: skip teammates
    if ESP.TeamCheck and LP.Team and pl.Team and pl.Team==LP.Team then hideESP(pl); return end
    local myR=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local root=ch:FindFirstChild("HumanoidRootPart"); local head=ch:FindFirstChild("Head")
    if not root or not head then hideESP(pl); return end
    if myR and ESP.DistLimit<math.huge and (myR.Position-root.Position).Magnitude>ESP.DistLimit then hideESP(pl); return end
    if ESP.VisOnly and not canSee(ch) then hideESP(pl); return end
    local tV=w2s(head.Position+Vector3.new(0,head.Size.Y/2+0.3,0))
    local bV=w2s(root.Position-Vector3.new(0,3.1,0))
    local cV,on=w2s(root.Position)
    if not on then hideESP(pl); return end
    local ht=math.abs(tV.Y-bV.Y); local wd=ht*0.55
    local Lx,Rx,Ty,By=cV.X-wd/2,cV.X+wd/2,tV.Y,bV.Y
    local cl=ht*0.25

    -- full 2D box
    local sb=ESP.Enabled and ESP.BoxEnabled and ESP.BoxMode=="2D"
    pcall(function()
        d.BT.From=Vector2.new(Lx,Ty);d.BT.To=Vector2.new(Rx,Ty);d.BT.Color=ESP.BoxColor;d.BT.Thickness=ESP.BoxThick;d.BT.Visible=sb
        d.BB.From=Vector2.new(Lx,By);d.BB.To=Vector2.new(Rx,By);d.BB.Color=ESP.BoxColor;d.BB.Thickness=ESP.BoxThick;d.BB.Visible=sb
        d.BL.From=Vector2.new(Lx,Ty);d.BL.To=Vector2.new(Lx,By);d.BL.Color=ESP.BoxColor;d.BL.Thickness=ESP.BoxThick;d.BL.Visible=sb
        d.BR.From=Vector2.new(Rx,Ty);d.BR.To=Vector2.new(Rx,By);d.BR.Color=ESP.BoxColor;d.BR.Thickness=ESP.BoxThick;d.BR.Visible=sb
    end)
    -- box fill (square overlay)
    pcall(function()
        local bf=ESP.Enabled and ESP.BoxFill and (ESP.BoxMode=="2D" or ESP.BoxMode=="Corner")
        d.BFill.Position=Vector2.new(Lx,Ty); d.BFill.Size=Vector2.new(Rx-Lx,By-Ty)
        d.BFill.Color=ESP.BoxFillColor or Color3.fromRGB(100,50,200)
        d.BFill.Transparency=ESP.BoxFillTrans or 0.85; d.BFill.Visible=bf
    end)
    -- corner box
