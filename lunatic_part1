mkStroke(Color3.fromRGB(40,30,60),1,dotCursor)

local uiVisible=true
local function setUIVisible(v)
    uiVisible=v; MF.Visible=v
    UserInputService.MouseIconEnabled=not v
    dotCursor.Visible=v
    -- restore proper mouse behavior: free when ui open, locked when closed
    pcall(function()
        UserInputService.MouseBehavior=v and Enum.MouseBehavior.Default or Enum.MouseBehavior.LockCenter
    end)
    tw(blurFX,{Size=v and T.blurAmt or 0},0.3)
    tw(darkOverlay,{BackgroundTransparency=v and (1-T.overlayAlpha) or 1},0.3)
end

-- dot cursor follows mouse
RunService.RenderStepped:Connect(function()
    if not uiVisible then return end
    local mp=UserInputService:GetMouseLocation()
    dotCursor.Position=UDim2.new(0,mp.X-3,0,mp.Y-3)
end)

local uiToggleKB=regKB("Toggle UI",Enum.KeyCode.RightShift,"Toggle")
addKBCb(uiToggleKB,function() setUIVisible(not uiVisible) end)

local clipInner=ni("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ClipsDescendants=true,ZIndex=2},MF)

-- ─── drag from ANYWHERE on window ─────
local _drag=false; local _dOx,_dOy=0,0
MF.InputBegan:Connect(function(i)
    -- only start drag if not clicking a button-like element
    if i.UserInputType==Enum.UserInputType.MouseButton1 then
        _drag=true; _dOx=i.Position.X-MF.AbsolutePosition.X; _dOy=i.Position.Y-MF.AbsolutePosition.Y
    end
end)
MF.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then _drag=false end
end)
UserInputService.InputChanged:Connect(function(i)
    if _drag and i.UserInputType==Enum.UserInputType.MouseMovement then
        MF.Position=UDim2.new(0,i.Position.X-_dOx,0,i.Position.Y-_dOy)
    end
end)


