--   RENDER LOOP
-- ═══════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    -- aimbot fov
    if abFovRing then pcall(function()
        local ctr=aimCenter(AB.FOVMouse)
        abFovRing.Position=ctr; abFovRing.Radius=AB.FOVSize; abFovRing.Color=AB.FOVColor; abFovRing.Visible=AB.ShowFOV
        abFovFill.Position=ctr; abFovFill.Radius=AB.FOVSize; abFovFill.Color=AB.FOVColor
        abFovFill.Transparency=AB.FOVFillAlpha; abFovFill.Visible=AB.FOVFill and AB.ShowFOV
    end) end
    -- sa fov
    if saFovRing then pcall(function()
        local ctr=aimCenter(SA.FOVMouse)
        saFovRing.Position=ctr; saFovRing.Radius=SA.FOVSize; saFovRing.Color=SA.FOVColor; saFovRing.Visible=SA.ShowFOV
        saFovFill.Position=ctr; saFovFill.Radius=SA.FOVSize; saFovFill.Color=SA.FOVColor
        saFovFill.Transparency=SA.FOVFillAlpha; saFovFill.Visible=SA.FOVFill and SA.ShowFOV
    end) end

    -- aimbot — camera move only, completely separate from SA
    if AB.Enabled then
        local tgt=nil
        if AB.StickyAim and AB._stickyPl then
            local ch=AB._stickyPl.Character
            local hum=ch and ch:FindFirstChild("Humanoid")
            if hum and hum.Health>0 then
                local part=ch:FindFirstChild(AB.AimParts[1] or "Head") or ch:FindFirstChild("HumanoidRootPart")
                tgt=part; AB._stickyTarget=part
            else AB._stickyTarget=nil; AB._stickyPl=nil end
        end
        if not tgt then
            local bPl,bPart=getBestTarget(AB.FOVSize,AB.FOVMouse,AB.AimParts,AB.VisCheck,AB.TeamCheck,AB.DistLimit,AB.HealthCheck and AB.HealthMin or 0,AB.KnockCheck)
            tgt=bPart
            if AB.StickyAim and bPl then AB._stickyPl=bPl; AB._stickyTarget=bPart end
        end
        if tgt then
            local aimPos=tgt.Position
            if AB.Prediction then
                local root=tgt.Parent and tgt.Parent:FindFirstChild("HumanoidRootPart")
                if root then aimPos=predPos(root,AB.PredX,AB.PredY) end
            end
            if AB.Mode=="CamLock" then
                Cam.CFrame=Cam.CFrame:Lerp(CFrame.new(Cam.CFrame.Position,aimPos),1/math.max(AB.Smooth,1))
            end
        end
    else
        if AB._stickyTarget or AB._stickyPl then AB._stickyTarget=nil; AB._stickyPl=nil end
    end

    -- silent aim — ONLY updates _saTarget, never touches camera
    -- SA.VisCheck deliberately off so target is locked through walls (hook does redirection silently)
    if SA.Enabled then
        local _,part=getBestTarget(SA.FOVSize,SA.FOVMouse,SA.HitParts,false,SA.TeamCheck,SA.DistLimit,0,false)
        _saTarget=part
    else
        _saTarget=nil
    end
    -- sa standalone tracer line
    if _saTracerLine then pcall(function()
        if SA.Enabled and SA.Tracer and _saTarget then
            local tp,tOn=w2s(_saTarget.Position)
            _saTracerLine.From=aimCenter(SA.FOVMouse)
            _saTracerLine.To=tp; _saTracerLine.Color=SA.TracerColor; _saTracerLine.Visible=tOn
        else _saTracerLine.Visible=false end
    end) end

    -- esp
    for _,pl in ipairs(Players:GetPlayers()) do
        if ESP.Enabled then updateESP(pl) else hideESP(pl) end
    end

    -- custom cursor
    if CursorDraw.Enabled then
        if CursorDraw.Rainbow then CursorDraw._rainbowHue=(CursorDraw._rainbowHue+dt*0.4)%1 end
        local mx=UserInputService:GetMouseLocation().X; local my=UserInputService:GetMouseLocation().Y
        if CursorDraw.Spin then CursorDraw._angle=(CursorDraw._angle+CursorDraw.SpinSpeed*dt)%360 end
        local ang=math.rad(CursorDraw._angle); local L=CursorDraw.Length
        local angles={ang,ang+math.pi/2,ang+math.pi,ang+math.pi*1.5}
        for i,a in ipairs(angles) do
            pcall(function()
                local ln=_curLines[i*2-1]; local lo=_curLines[i*2]
                ln.From=Vector2.new(mx+math.cos(a)*4,my+math.sin(a)*4)
                ln.To=Vector2.new(mx+math.cos(a)*(4+L),my+math.sin(a)*(4+L))
                local col=CursorDraw.Rainbow and Color3.fromHSV(CursorDraw._rainbowHue,1,1) or CursorDraw.Color
                ln.Color=col; ln.Thickness=CursorDraw.Thickness; ln.Visible=true; ln.ZIndex=10
                if CursorDraw.Outline and lo then
                    local ot = CursorDraw.OutlineThick or 1
                    lo.From=Vector2.new(mx+math.cos(a)*3,my+math.sin(a)*3)
                    lo.To=Vector2.new(mx+math.cos(a)*(5+L),my+math.sin(a)*(5+L))
                    -- dark version of the line color for outline (not pure black)
                    lo.Color=Color3.fromRGB(
                        math.floor(col.R*255*0.12),
                        math.floor(col.G*255*0.12),
                        math.floor(col.B*255*0.12)
                    )
                    lo.Thickness=CursorDraw.Thickness+ot; lo.ZIndex=8; lo.Visible=true
                elseif lo then lo.Visible=false end
            end)
        end
    else for _,ln in ipairs(_curLines) do pcall(function() ln.Visible=false end) end end

    applyWorldFX()
end)

